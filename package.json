{
  "name": "clawboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:backend": "bash scripts/test_backend.sh",
    "test:backend:host": "CLAWBOARD_BACKEND_TEST_MODE=host bash scripts/test_backend.sh",
    "test:backend:docker": "CLAWBOARD_BACKEND_TEST_MODE=docker bash scripts/test_backend.sh",
    "test:classifier": "bash scripts/repo_python.sh -m unittest discover -s classifier/tests -p \"test_*.py\" && bash scripts/repo_python.sh -m unittest discover -s tests/classifier -p \"test_*.py\"",
    "test:coverage:logger": "node --test --experimental-test-coverage --test-coverage-include=extensions/clawboard-logger/ignore-session.js --test-coverage-include=extensions/clawboard-logger/session-key.js --test-coverage-include=extensions/clawboard-logger/strings.js --test-coverage-lines=90 --test-coverage-functions=90 extensions/clawboard-logger/*.test.mjs",
    "test:coverage:python": "bash scripts/test_python_coverage.sh",
    "test:coverage": "pnpm run test:coverage:logger && pnpm run test:coverage:python",
    "test:logger": "node --test extensions/clawboard-logger/*.test.mjs",
    "test:scripts": "node --test tests/scripts/*.test.mjs",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test -c playwright.ci.config.ts",
    "test:e2e:live-smoke": "bash scripts/repo_live_smoke.sh",
    "test:team-production": "node scripts/team_production_readiness_smoke.mjs",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:ci": "playwright test -c playwright.visual.ci.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "test:all": "pnpm run ci:full",
    "build:logger": "tsc -p extensions/clawboard-logger/tsconfig.plugin.json",
    "check:publish-safety": "bash scripts/check_publish_safety.sh",
    "check:logger-runtime-sync": "pnpm run build:logger && git diff --exit-code -- extensions/clawboard-logger/*.js",
    "ci:core": "pnpm run lint && pnpm run typecheck && pnpm run check:logger-runtime-sync && pnpm run test:coverage && pnpm run test:backend && pnpm run test:classifier && pnpm run test:logger && pnpm run test:scripts && pnpm run build:webpack",
    "ci:full": "pnpm run ci:core && pnpm run test:e2e:ci && pnpm run test:visual:ci"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "strip-ansi": "^7.2.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.30.3"
}
